# Copia este archivo como .env y completa los valores reales
# NUNCA subas el .env al repositorio

# Django
SECRET_KEY=django-insecure-cambia-esto-por-una-clave-segura-de-50-caracteres
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=impactoweb_db
DB_USER=DB_USER
DB_PASSWORD=DB_PASSWORD
DB_HOST=localhost
DB_PORT=5432

# Email SMTP (Gmail)
# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=hola@impactoweb.agency
EMAIL_HOST_PASSWORD=PASSWORD
DEFAULT_FROM_EMAIL=ImpactoWeb <hola@impactoweb.agency>
CONTACT_EMAIL=hola@impactoweb.agency

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
